# Copy this file to src/main/resources/application-local.properties for local-only secrets.
# This file is only an example and is safe to commit.

DB_URL=jdbc:mysql://localhost:3306/techstore?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_db_password

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRATION_MS=86400000
AUTH_COOKIE_NAME=TS_ACCESS_TOKEN
AUTH_COOKIE_SECURE=false
RESET_TOKEN_EXPIRY_MINUTES=30
# Keep false to deliver reset token via email only; set true only for local debug without SMTP.
FORGOT_PASSWORD_EXPOSE_TOKEN=false
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
ORDER_ONLINE_RESERVATION_MINUTES=20
ORDER_RESERVATION_EXPIRE_CHECK_MS=60000
ORDER_RESERVATION_EXPIRE_INITIAL_MS=15000

SUPER_ADMIN_PASSWORD=SuperAdmin@123
ADMIN_PASSWORD=Admin@123
APP_SEED_ORDERS_EXTRA_PER_RUN=0

OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_REVIEW_MODEL=gemini-2.5-flash
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=420
COMFYUI_POLL_INTERVAL_MS=1500
COMFYUI_UNET_NAME=qwen_image_edit_fp8_e4m3fn.safetensors
COMFYUI_CLIP_NAME=qwen_2.5_vl_7b_fp8_scaled.safetensors
COMFYUI_VAE_NAME=qwen_image_vae.safetensors
COMFYUI_LORA_NAME=Qwen-Image-Edit-Lightning-4steps-V1.0-bf16.safetensors
COMFYUI_MEGAPIXELS=0.25
COMFYUI_RESOLUTION_STEPS=1
COMFYUI_TURBO_ENABLED=true
COMFYUI_STEPS_FAST=4
COMFYUI_STEPS_SLOW=20
COMFYUI_CFG_FAST=1.0
COMFYUI_CFG_SLOW=2.5
COMFYUI_OUTPUT_PREFIX=TechStoreAI

PAYMENT_MOCK_PROVIDER=MOCK_GATEWAY
PAYMENT_MOCK_WEBHOOK_SECRET=change-me-mock-webhook-secret

APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@techparadise.local
APP_MAIL_NOTIFY_ADMIN=
APP_MAIL_FORGOT_TEST_TO=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:8080/payments/vnpay/ipn
