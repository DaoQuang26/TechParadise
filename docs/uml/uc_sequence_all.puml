@startuml UC10_sequence
title UC10 - Danh gia san pham da mua
actor "Khach hang" as Customer
boundary "ReviewDialog" as ReviewDialog
control "CustomerProductReviewController" as ReviewController
control "ProductReviewService" as ReviewService
database "UserRepository / users" as UserRepo
database "ProductRepository / products" as ProductRepo
database "OrderItemRepository /\norder_items+orders" as OrderItemRepo
database "ProductReviewRepository /\nproduct_reviews" as ReviewRepo

Customer -> ReviewDialog : Chon san pham da mua
Customer -> ReviewDialog : Nhap rating (1..5) + content
Customer -> ReviewDialog : Bam nut Gui danh gia
ReviewDialog -> ReviewController : POST /api/customer/products/{productId}/reviews
ReviewController -> ReviewService : upsertMyReview(productId,username,request)
ReviewService -> UserRepo : findByUsername(username)
ReviewService -> ProductRepo : findById(productId)
ReviewService -> OrderItemRepo : existsByUserAndProductAndOrderStatus(\nDELIVERED)
alt Da mua va da giao hang
  ReviewService -> ReviewRepo : findByProductIdAndUserId()
  ReviewService -> ReviewRepo : save(create/update review)
  ReviewRepo --> ReviewService : ProductReview
  ReviewService --> ReviewController : ProductReviewResponse
  ReviewController --> ReviewDialog : 201 + review data
  ReviewDialog --> Customer : Hien thi danh gia moi
else Chua mua/chua giao or rating noi dung khong hop le
  ReviewService --> ReviewController : IllegalArgumentException
  ReviewController --> ReviewDialog : 400 + thong bao loi
  ReviewDialog --> Customer : Hien thi loi
else Loi CSDL
  ReviewRepo --> ReviewService : DataAccessException
  ReviewController --> ReviewDialog : 500 Loi he thong
  ReviewDialog --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC11_sequence
title UC11 - Quan ly danh muc san pham (Admin)
actor "Admin" as Admin
boundary "AdminCategoryPage" as AdminCategoryPage
control "CategoryController" as CategoryController
control "CategoryService" as CategoryService
control "AdminAuditLogService" as AuditService
database "CategoryRepository / categories" as CategoryRepo
database "ProductRepository / products" as ProductRepo
database "AdminAuditLogRepository /\nadmin_audit_logs" as AuditRepo

Admin -> AdminCategoryPage : Mo trang Danh muc
AdminCategoryPage -> CategoryController : GET /api/public/categories
CategoryController -> CategoryService : findAll()
CategoryService -> CategoryRepo : findAll()
CategoryRepo --> CategoryService : List<Category>
CategoryService --> CategoryController : List<Category>
CategoryController --> AdminCategoryPage : Hien thi danh sach

alt Bam nut Them danh muc
  Admin -> AdminCategoryPage : Nhap name, description + Bam Luu
  AdminCategoryPage -> CategoryController : POST /api/admin/categories
  CategoryController -> CategoryService : create(category)
  CategoryService -> CategoryRepo : existsByNameIgnoreCase(name)
  CategoryService -> CategoryRepo : save(category)
  CategoryController -> AuditService : logAction(CATEGORY_CREATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  CategoryController --> AdminCategoryPage : 201 Created
else Bam nut Sua danh muc
  Admin -> AdminCategoryPage : Sua name/description + Bam Luu
  AdminCategoryPage -> CategoryController : PUT /api/admin/categories/{id}
  CategoryController -> CategoryService : update(id,category)
  CategoryService -> CategoryRepo : findById(id)
  CategoryService -> CategoryRepo : existsByNameIgnoreCaseAndIdNot()
  CategoryService -> CategoryRepo : save(category)
  CategoryController -> AuditService : logAction(CATEGORY_UPDATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  CategoryController --> AdminCategoryPage : 200 Updated
else Bam nut Xoa danh muc
  Admin -> AdminCategoryPage : Bam Xoa
  AdminCategoryPage -> CategoryController : DELETE /api/admin/categories/{id}
  CategoryController -> CategoryService : delete(id)
  CategoryService -> CategoryRepo : existsById(id)
  CategoryService -> ProductRepo : countByCategoryId(id)
  CategoryService -> CategoryRepo : deleteById(id)
  CategoryController -> AuditService : logAction(CATEGORY_DELETE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  CategoryController --> AdminCategoryPage : 204 No Content
end

alt Ten trung / category dang duoc dung / khong ton tai
  CategoryService --> CategoryController : IllegalArgumentException
  CategoryController --> AdminCategoryPage : 400 + thong bao loi
  AdminCategoryPage --> Admin : Hien thi loi
else Loi CSDL
  CategoryRepo --> CategoryService : DataAccessException
  CategoryController --> AdminCategoryPage : 500 Loi he thong
  AdminCategoryPage --> Admin : Hien thi Loi he thong
end
@enduml

@startuml UC12_sequence
title UC12 - Quan ly san pham (Admin)
actor "Admin" as Admin
boundary "AdminProductPage" as AdminProductPage
control "AdminProductController" as AdminProductController
control "ProductService" as ProductService
control "ProductVariantService" as ProductVariantService
control "AdminAuditLogService" as AuditService
database "ProductRepository / products" as ProductRepo
database "CategoryRepository / categories" as CategoryRepo
database "ProductVariantRepository /\nproduct_variants" as VariantRepo
database "OrderItemRepository / order_items" as OrderItemRepo
database "CartItemRepository / cart_items" as CartItemRepo
database "ProductReviewRepository /\nproduct_reviews" as ReviewRepo
database "AdminAuditLogRepository /\nadmin_audit_logs" as AuditRepo

Admin -> AdminProductPage : Mo trang Quan ly san pham
AdminProductPage -> AdminProductController : GET /api/admin/products/paged
AdminProductController -> ProductService : getAdminProductsPaged(...)
ProductService -> ProductRepo : searchPublicProducts(...)
ProductRepo --> ProductService : Page<Product>
ProductService --> AdminProductController : Page<Product>
AdminProductController --> AdminProductPage : Hien thi danh sach san pham

alt Bam nut Them san pham
  Admin -> AdminProductPage : Nhap form + Bam Luu
  AdminProductPage -> AdminProductController : POST /api/admin/products
  AdminProductController -> ProductService : createProduct(product)
  ProductService -> CategoryRepo : findById(categoryId)
  ProductService -> ProductRepo : save(product)
  AdminProductController -> AuditService : logAction(PRODUCT_CREATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminProductController --> AdminProductPage : 201 Created
else Bam nut Sua san pham
  Admin -> AdminProductPage : Sua form + Bam Cap nhat
  AdminProductPage -> AdminProductController : PUT /api/admin/products/{id}
  AdminProductController -> ProductService : updateProduct(id,product)
  ProductService -> ProductRepo : findById(id)
  ProductService -> CategoryRepo : findById(categoryId)
  ProductService -> ProductRepo : save(product)
  AdminProductController -> AuditService : logAction(PRODUCT_UPDATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminProductController --> AdminProductPage : 200 Updated
else Bam nut Quan ly bien the
  Admin -> AdminProductPage : Chinh bien the + Bam Luu
  AdminProductPage -> AdminProductController : PUT /api/admin/products/{id}/variants
  AdminProductController -> ProductVariantService : replaceProductVariants(id,requests)
  ProductVariantService -> VariantRepo : save/delete variants
  AdminProductController -> AuditService : logAction(PRODUCT_VARIANT_UPDATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminProductController --> AdminProductPage : Danh sach bien the moi
else Bam nut Xoa san pham
  Admin -> AdminProductPage : Bam Xoa
  AdminProductPage -> AdminProductController : DELETE /api/admin/products/{id}
  AdminProductController -> ProductService : deleteProduct(id)
  ProductService -> OrderItemRepo : countByProductId(id)
  ProductService -> CartItemRepo : deleteByProductId(id)
  ProductService -> VariantRepo : deleteByProductId(id)
  ProductService -> ReviewRepo : deleteByProductId(id)
  ProductService -> ProductRepo : deleteById(id)
  AdminProductController -> AuditService : logAction(PRODUCT_DELETE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminProductController --> AdminProductPage : 204 No Content
end

alt Du lieu khong hop le / category khong ton tai /\nkhong the xoa vi da co order
  ProductService --> AdminProductController : IllegalArgumentException
  AdminProductController --> AdminProductPage : 400 + thong bao loi
  AdminProductPage --> Admin : Hien thi loi
else Loi CSDL
  ProductRepo --> ProductService : DataAccessException
  AdminProductController --> AdminProductPage : 500 Loi he thong
  AdminProductPage --> Admin : Hien thi Loi he thong
end
@enduml

@startuml UC13_sequence
title UC13 - Quan ly don hang (Admin)
actor "Admin" as Admin
boundary "AdminOrderPage" as AdminOrderPage
control "AdminOrderController" as AdminOrderController
control "OrderService" as OrderService
control "OrderStatusHistoryService" as OrderStatusHistoryService
control "AdminAuditLogService" as AuditService
control "EmailNotificationService" as EmailNotificationService
database "OrderRepository / orders + order_items" as OrderRepo
database "OrderStatusHistoryRepository /\norder_status_history" as HistoryRepo
database "AdminAuditLogRepository /\nadmin_audit_logs" as AuditRepo

Admin -> AdminOrderPage : Mo trang Quan ly don
AdminOrderPage -> AdminOrderController : GET /api/admin/orders/paged
AdminOrderController -> OrderService : findAllSummariesPaged(...)
OrderService -> OrderRepo : searchAdminOrders(...)
OrderRepo --> OrderService : Page<Order>
OrderService --> AdminOrderController : Page<OrderSummaryResponse>
AdminOrderController --> AdminOrderPage : Hien thi danh sach don

Admin -> AdminOrderPage : Bam vao 1 don hang
AdminOrderPage -> AdminOrderController : GET /api/admin/orders/{id}
AdminOrderController -> OrderService : getOrderDetailForAdmin(id)
OrderService -> OrderRepo : findByIdWithItems(id)
OrderService -> HistoryRepo : findByOrderIdOrderByCreatedAtAsc(id)
OrderService --> AdminOrderController : OrderDetailResponse
AdminOrderController --> AdminOrderPage : Hien thi chi tiet + lich su

alt Bam nut Cap nhat trang thai
  Admin -> AdminOrderPage : Chon status moi + Bam Luu
  AdminOrderPage -> AdminOrderController : PATCH /api/admin/orders/{id}/status
  AdminOrderController -> OrderService : updateStatusSummary(id,status,actor)
  OrderService -> OrderRepo : findByIdWithItems(id)
  OrderService -> OrderRepo : save(order status moi)
  OrderService -> OrderStatusHistoryService : saveHistorySafe(...)
  OrderService -> EmailNotificationService : sendOrderStatusChanged(...)
  AdminOrderController -> AuditService : logAction(ORDER_STATUS_UPDATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminOrderController --> AdminOrderPage : OrderSummaryResponse
else Bam nut Xoa don
  Admin -> AdminOrderPage : Bam Xoa don
  AdminOrderPage -> AdminOrderController : DELETE /api/admin/orders/{id}
  AdminOrderController -> OrderService : deleteOrderByAdmin(id,actor)
  OrderService -> OrderRepo : findByIdWithItems(id)
  OrderService -> HistoryRepo : deleteByOrderId(id)
  OrderService -> OrderRepo : delete(order)
  AdminOrderController -> AuditService : logAction(ORDER_DELETE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  AdminOrderController --> AdminOrderPage : MessageResponse "Da xoa"
end

alt Trang thai cap nhat khong hop le /\nkhong cho xoa don da giao/da thanh toan
  OrderService --> AdminOrderController : IllegalArgumentException
  AdminOrderController --> AdminOrderPage : 400 + thong bao loi
  AdminOrderPage --> Admin : Hien thi loi
else Loi CSDL
  OrderRepo --> OrderService : DataAccessException
  AdminOrderController --> AdminOrderPage : 500 Loi he thong
  AdminOrderPage --> Admin : Hien thi Loi he thong
end
@enduml

@startuml UC14_sequence
title UC14 - Quan ly tai khoan (Admin/Super Admin)
actor "Admin" as Admin
actor "Super Admin" as SuperAdmin
boundary "AdminUserPage" as AdminUserPage
control "UserManagementController" as UserManagementController
control "UserManagementService" as UserManagementService
control "AdminAuditLogService" as AuditService
database "UserRepository / users" as UserRepo
database "OrderRepository / orders" as OrderRepo
database "CartItemRepository / cart_items" as CartItemRepo
database "AdminAuditLogRepository /\nadmin_audit_logs" as AuditRepo

Admin -> AdminUserPage : Mo trang Quan ly tai khoan
AdminUserPage -> UserManagementController : GET /api/admin/users/paged
UserManagementController -> UserManagementService : findUsersPaged(...)
UserManagementService -> UserRepo : searchAdminUsers(...)
UserRepo --> UserManagementService : Page<User>
UserManagementService --> UserManagementController : Page<User>
UserManagementController --> AdminUserPage : Hien thi danh sach user

alt Admin bam nut Them tai khoan
  Admin -> AdminUserPage : Nhap fullName, username, email,\npassword, role + Bam Luu
  AdminUserPage -> UserManagementController : POST /api/admin/users
  UserManagementController -> UserManagementService : createUser(request, canCreateAdminRole)
  UserManagementService -> UserRepo : existsByUsernameIgnoreCase()
  UserManagementService -> UserRepo : existsByEmailIgnoreCase()
  UserManagementService -> UserRepo : save(User)
  UserManagementController -> AuditService : logAction(USER_CREATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  UserManagementController --> AdminUserPage : 201 Created
else Admin bam nut Sua thong tin tai khoan
  Admin -> AdminUserPage : Sua thong tin + Bam Cap nhat
  AdminUserPage -> UserManagementController : PUT /api/admin/users/{id}
  UserManagementController -> UserManagementService : updateUserInfo(id,request)
  UserManagementService -> UserRepo : findById(id)
  UserManagementService -> UserRepo : findByUsernameIgnoreCase()
  UserManagementService -> UserRepo : findByEmailIgnoreCase()
  UserManagementService -> UserRepo : save(User)
  UserManagementController -> AuditService : logAction(USER_UPDATE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  UserManagementController --> AdminUserPage : 200 Updated
else Admin bam nut Xoa customer
  Admin -> AdminUserPage : Bam Xoa
  AdminUserPage -> UserManagementController : DELETE /api/admin/users/{id}
  UserManagementController -> UserManagementService : deleteCustomer(id)
  UserManagementService -> UserRepo : findById(id)
  UserManagementService -> OrderRepo : countByUserId(id)
  UserManagementService -> CartItemRepo : deleteByUserId(id)
  UserManagementService -> UserRepo : deleteById(id)
  UserManagementController -> AuditService : logAction(USER_DELETE)
  AuditService -> AuditRepo : save(admin_audit_logs)
  UserManagementController --> AdminUserPage : 204 No Content
end

SuperAdmin -> AdminUserPage : Bam nut Doi role user
AdminUserPage -> UserManagementController : PUT /api/super-admin/users/{id}/role
UserManagementController -> UserManagementService : updateRole(id,role)
UserManagementService -> UserRepo : findById(id)
UserManagementService -> UserRepo : save(role moi)
UserManagementController -> AuditService : logAction(USER_ROLE_UPDATE)
AuditService -> AuditRepo : save(admin_audit_logs)
UserManagementController --> AdminUserPage : User sau khi doi role

alt Trung username/email / khong du quyen /\nco gang tao-gan SUPER_ADMIN / user da co don
  UserManagementService --> UserManagementController : IllegalArgumentException
  UserManagementController --> AdminUserPage : 400 + thong bao loi
  AdminUserPage --> Admin : Hien thi loi
else Loi CSDL
  UserRepo --> UserManagementService : DataAccessException
  UserManagementController --> AdminUserPage : 500 Loi he thong
  AdminUserPage --> Admin : Hien thi Loi he thong
end
@enduml

@startuml UC15_sequence
