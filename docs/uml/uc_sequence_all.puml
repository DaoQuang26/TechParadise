@startuml UC01_sequence
title UC01 - Dang ky tai khoan
actor "Khach hang" as Customer
boundary "RegisterPage" as RegisterPage
control "AuthController" as AuthController
control "AuthService" as AuthService
control "PasswordEncoder" as PasswordEncoder
database "UserRepository / users" as UserRepo

Customer -> RegisterPage : Mo form Dang ky
Customer -> RegisterPage : Nhap fullName, username, email,\nphone, address, password, confirmPassword
Customer -> RegisterPage : Bam nut Dang ky
RegisterPage -> AuthController : POST /api/auth/register
AuthController -> AuthService : register(RegisterRequest)
AuthService -> UserRepo : existsByUsernameIgnoreCase(username)
UserRepo --> AuthService : true/false
AuthService -> UserRepo : existsByEmailIgnoreCase(email)
UserRepo --> AuthService : true/false
alt Du lieu hop le
  AuthService -> PasswordEncoder : encode(password)
  PasswordEncoder --> AuthService : passwordHash
  AuthService -> UserRepo : save(User role=CUSTOMER)
  UserRepo --> AuthService : User
  AuthService --> AuthController : User
  AuthController --> RegisterPage : 201 Created
  RegisterPage --> Customer : Thong bao dang ky thanh cong
else Loi du lieu / username-email trung
  AuthService --> AuthController : IllegalArgumentException
  AuthController --> RegisterPage : 400 + message loi
  RegisterPage --> Customer : Hien thi loi
else Loi CSDL
  UserRepo --> AuthService : DataAccessException
  AuthController --> RegisterPage : 500 Loi he thong
  RegisterPage --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC02_sequence
title UC02 - Dang nhap
actor "Nguoi dung (Customer/Admin)" as User
boundary "LoginPage" as LoginPage
control "AuthController" as AuthController
control "AuthService" as AuthService
control "AuthenticationManager" as AuthenticationManager
control "JwtService" as JwtService
database "UserRepository / users" as UserRepo

User -> LoginPage : Mo form Dang nhap
User -> LoginPage : Nhap username/email + password
User -> LoginPage : Bam nut Dang nhap
LoginPage -> AuthController : POST /api/auth/login
AuthController -> AuthService : login(LoginRequest)
AuthService -> UserRepo : findByUsernameIgnoreCase()\nor findByEmailIgnoreCase()
UserRepo --> AuthService : User/null
AuthService -> AuthenticationManager : authenticate(identifier,password)
alt Dang nhap dung
  AuthenticationManager --> AuthService : Authenticated
  AuthService -> JwtService : generateToken(userDetails)
  JwtService --> AuthService : JWT token
  AuthService -> UserRepo : save(reset failed attempts,\nlockout, lastLoginAt)
  AuthService --> AuthController : AuthResponse(token, role)
  AuthController --> LoginPage : Set HttpOnly cookie + AuthResponse
  LoginPage --> User : Chuyen vao man hinh theo quyen
else Sai thong tin / tai khoan tam khoa
  AuthenticationManager --> AuthService : AuthenticationException
  AuthService -> UserRepo : save(failedLoginAttempts/lockout)
  AuthService --> AuthController : IllegalArgumentException
  AuthController --> LoginPage : 400 + message loi
  LoginPage --> User : Hien thi thong bao loi
else Loi CSDL
  UserRepo --> AuthService : DataAccessException
  AuthController --> LoginPage : 500 Loi he thong
  LoginPage --> User : Hien thi Loi he thong
end
@enduml

@startuml UC03_sequence
title UC03 - Quen va dat lai mat khau
actor "Nguoi dung" as User
boundary "ForgotResetPage" as ForgotResetPage
control "AuthController" as AuthController
control "PasswordResetService" as PasswordResetService
control "EmailNotificationService" as EmailService
control "PasswordEncoder" as PasswordEncoder
database "UserRepository / users" as UserRepo
database "PasswordResetTokenRepository /\npassword_reset_tokens" as TokenRepo

User -> ForgotResetPage : Nhap email/username
User -> ForgotResetPage : Bam nut Gui ma reset
ForgotResetPage -> AuthController : POST /api/auth/forgot-password
AuthController -> PasswordResetService : forgotPassword(identifier)
PasswordResetService -> UserRepo : findByUsernameIgnoreCase()\nor findByEmailIgnoreCase()
UserRepo --> PasswordResetService : User/null
alt Tai khoan ton tai
  PasswordResetService -> TokenRepo : save(tokenHash, expiresAt, usedAt=null)
  PasswordResetService -> EmailService : sendPasswordResetToken(user, rawToken)
  PasswordResetService --> AuthController : ForgotPasswordResponse
  AuthController --> ForgotResetPage : 200 + thong bao tao token
else Tai khoan khong ton tai
  PasswordResetService --> AuthController : Generic response (an toan)
  AuthController --> ForgotResetPage : 200 + thong bao chung
else Loi CSDL
  TokenRepo --> PasswordResetService : DataAccessException
  AuthController --> ForgotResetPage : 500 Loi he thong
end

User -> ForgotResetPage : Nhap token + mat khau moi
User -> ForgotResetPage : Bam nut Dat lai mat khau
ForgotResetPage -> AuthController : POST /api/auth/reset-password
AuthController -> PasswordResetService : resetPassword(token,newPassword)
PasswordResetService -> TokenRepo : findByTokenHash()
alt Token hop le va chua dung
  PasswordResetService -> PasswordEncoder : encode(newPassword)
  PasswordEncoder --> PasswordResetService : passwordHash
  PasswordResetService -> UserRepo : save(user.password)
  PasswordResetService -> TokenRepo : findByUserIdAndUsedAtIsNull()
  PasswordResetService -> TokenRepo : mark usedAt cho token
  PasswordResetService --> AuthController : MessageResponse success
  AuthController --> ForgotResetPage : 200 Dat lai thanh cong
else Token sai/het han/da dung or password moi khong hop le
  PasswordResetService --> AuthController : IllegalArgumentException
  AuthController --> ForgotResetPage : 400 + thong bao loi
else Loi CSDL
  TokenRepo --> PasswordResetService : DataAccessException
  AuthController --> ForgotResetPage : 500 Loi he thong
end
@enduml

@startuml UC04_sequence
title UC04 - Xem san pham theo danh muc
actor "Khach hang" as Customer
boundary "CategoryProductPage" as CategoryProductPage
control "CategoryController" as CategoryController
control "CategoryService" as CategoryService
control "ProductController" as ProductController
control "ProductService" as ProductService
database "CategoryRepository / categories" as CategoryRepo
database "ProductRepository / products" as ProductRepo

Customer -> CategoryProductPage : Bam menu San pham
CategoryProductPage -> CategoryController : GET /api/public/categories
CategoryController -> CategoryService : findAll()
CategoryService -> CategoryRepo : findAll()
CategoryRepo --> CategoryService : List<Category>
CategoryService --> CategoryController : Danh sach danh muc
CategoryController --> CategoryProductPage : Hien thi danh muc

Customer -> CategoryProductPage : Chon 1 danh muc
CategoryProductPage -> ProductController : GET /api/public/products?categoryId=...
ProductController -> ProductService : getPublicProducts(keyword=null, categoryId)
ProductService -> ProductRepo : findByCategoryId(categoryId)
ProductRepo --> ProductService : List<Product>
alt Co san pham
  ProductService --> ProductController : Danh sach san pham
  ProductController --> CategoryProductPage : Render product cards
  CategoryProductPage --> Customer : Hien thi ket qua
else Khong co san pham phu hop
  ProductService --> ProductController : []
  ProductController --> CategoryProductPage : Danh sach rong
  CategoryProductPage --> Customer : "Khong co san pham"
else Loi CSDL
  ProductRepo --> ProductService : DataAccessException
  ProductController --> CategoryProductPage : 500 Loi he thong
  CategoryProductPage --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC05_sequence
title UC05 - Tim kiem san pham
actor "Khach hang" as Customer
boundary "SearchBar" as SearchBar
control "ProductController" as ProductController
control "ProductService" as ProductService
database "ProductRepository / products" as ProductRepo

Customer -> SearchBar : Nhap tu khoa vao o tim kiem
Customer -> SearchBar : Bam nut Tim kiem
SearchBar -> ProductController : GET /api/public/products?keyword=...
ProductController -> ProductService : getPublicProducts(keyword, categoryId?)
ProductService -> ProductRepo : findByNameContainingIgnoreCase()\nhoac searchPublicProducts()
ProductRepo --> ProductService : List<Product>
alt Tim thay ket qua
  ProductService --> ProductController : Danh sach san pham
  ProductController --> SearchBar : 200 + List<Product>
  SearchBar --> Customer : Hien thi danh sach ket qua
else Khong tim thay
  ProductService --> ProductController : []
  ProductController --> SearchBar : Danh sach rong
  SearchBar --> Customer : "Khong tim thay san pham"
else Loi CSDL
  ProductRepo --> ProductService : DataAccessException
  ProductController --> SearchBar : 500 Loi he thong
  SearchBar --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC06_sequence
title UC06 - Xem chi tiet san pham
actor "Khach hang" as Customer
boundary "ProductDetailPage" as ProductDetailPage
control "ProductController" as ProductController
control "ProductService" as ProductService
control "ProductVariantService" as ProductVariantService
control "ProductReviewService" as ProductReviewService
database "ProductRepository / products" as ProductRepo
database "ProductVariantRepository /\nproduct_variants" as VariantRepo
database "ProductReviewRepository /\nproduct_reviews" as ReviewRepo

Customer -> ProductDetailPage : Bam vao 1 san pham
ProductDetailPage -> ProductController : GET /api/public/products/{id}
ProductController -> ProductService : getProductById(id)
ProductService -> ProductRepo : findById(id)
alt San pham ton tai
  ProductRepo --> ProductService : Product
  ProductService --> ProductController : Product
  ProductController --> ProductDetailPage : Thong tin co ban

  ProductDetailPage -> ProductController : GET /api/public/products/{id}/variants
  ProductController -> ProductVariantService : getByProductId(id)
  ProductVariantService -> VariantRepo : findByProductIdOrderBySortOrderAscIdAsc()
  VariantRepo --> ProductVariantService : List<ProductVariant>
  ProductVariantService --> ProductController : VariantResponseList
  ProductController --> ProductDetailPage : Danh sach bien the

  ProductDetailPage -> ProductController : GET /api/public/products/{id}/reviews
  ProductController -> ProductReviewService : getPublicReviews(id,currentUser)
  ProductReviewService -> ReviewRepo : findByProductIdOrderByCreatedAtDesc(id)
  ReviewRepo --> ProductReviewService : List<ProductReview>
  ProductReviewService --> ProductController : ProductReviewResponseList
  ProductController --> ProductDetailPage : Danh sach review

  ProductDetailPage -> ProductController : GET /api/public/products/{id}/review-summary
  ProductController -> ProductReviewService : getReviewSummary(id,currentUser)
  ProductReviewService -> ReviewRepo : count/average/by-star
  ReviewRepo --> ProductReviewService : Summary data
  ProductReviewService --> ProductController : ProductReviewSummaryResponse
  ProductController --> ProductDetailPage : Tong quan danh gia
  ProductDetailPage --> Customer : Hien thi trang chi tiet day du
else San pham khong ton tai
  ProductRepo --> ProductService : empty
  ProductService --> ProductController : IllegalArgumentException
  ProductController --> ProductDetailPage : 400/404 + thong bao loi
  ProductDetailPage --> Customer : "Khong tim thay san pham"
else Loi CSDL
  ProductRepo --> ProductService : DataAccessException
  ProductController --> ProductDetailPage : 500 Loi he thong
  ProductDetailPage --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC07_sequence
title UC07 - Quan ly gio hang
actor "Khach hang" as Customer
boundary "CartPage" as CartPage
control "CustomerCartController" as CartController
control "CartService" as CartService
database "UserRepository / users" as UserRepo
database "ProductRepository / products" as ProductRepo
database "ProductVariantRepository /\nproduct_variants" as VariantRepo
database "CartItemRepository / cart_items" as CartItemRepo

Customer -> CartPage : Bam nut Them vao gio (tu trang san pham)
CartPage -> CartController : POST /api/customer/cart/items
CartController -> CartService : addItem(username, request)
CartService -> UserRepo : findByUsername(username)
CartService -> ProductRepo : findById(productId)
CartService -> VariantRepo : findByProductIdOrderBySortOrderAscIdAsc()
CartService -> CartItemRepo : findByUserIdAndProductIdAndProductVariantId()
CartService -> CartItemRepo : save(cartItem)
CartService -> CartItemRepo : findByUserIdOrderByUpdatedAtDesc()
CartService -> VariantRepo : findAllById(variantIds)
CartService --> CartController : CartResponse
CartController --> CartPage : Gio hang moi

alt Bam nut tang/giam so luong
  Customer -> CartPage : Bam nut + / -
  CartPage -> CartController : PUT /api/customer/cart/items/{productId}?variantId
  CartController -> CartService : setItemQuantity(...)
  CartService -> CartItemRepo : save(quantity moi)
  CartService --> CartController : CartResponse
  CartController --> CartPage : Cap nhat tong tien
else Bam nut Xoa dong san pham
  Customer -> CartPage : Bam nut Xoa
  CartPage -> CartController : DELETE /api/customer/cart/items/{productId}?variantId
  CartController -> CartService : removeItem(...)
  CartService -> CartItemRepo : delete(cartItem)
  CartService --> CartController : CartResponse
  CartController --> CartPage : Gio hang sau khi xoa
else Bam nut Xoa tat ca
  Customer -> CartPage : Bam nut Xoa tat ca
  CartPage -> CartController : DELETE /api/customer/cart
  CartController -> CartService : clearCart(username)
  CartService -> CartItemRepo : deleteByUserId(userId)
  CartService --> CartController : CartResponse rong
  CartController --> CartPage : Gio hang rong
end

alt Product/variant/quantity khong hop le
  CartService --> CartController : IllegalArgumentException
  CartController --> CartPage : 400 + thong bao loi
  CartPage --> Customer : Hien thi loi
else Loi CSDL
  CartItemRepo --> CartService : DataAccessException
  CartController --> CartPage : 500 Loi he thong
  CartPage --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC08_sequence
title UC08 - Dat hang va thanh toan
actor "Khach hang" as Customer
participant "Cong thanh toan\n(MOCK/VNPAY/MOMO)" as PaymentGateway
boundary "CheckoutPage" as CheckoutPage
control "CustomerOrderController" as CustomerOrderController
control "OrderService" as OrderService
control "PromotionService" as PromotionService
control "CustomerPaymentController" as CustomerPaymentController
control "PaymentService" as PaymentService
control "OrderStatusHistoryService" as OrderStatusHistoryService
control "EmailNotificationService" as EmailNotificationService
database "UserRepository / users" as UserRepo
database "ProductRepository / products" as ProductRepo
database "ProductVariantRepository /\nproduct_variants" as VariantRepo
database "PromotionRepository / promotions" as PromotionRepo
database "OrderRepository / orders + order_items" as OrderRepo

Customer -> CheckoutPage : Bam "Thanh toan" tu gio hoac "Mua ngay"
CheckoutPage --> Customer : Hien thi form recipientName,\nrecipientPhone, shippingAddress,\npaymentMethod, promotionCode
Customer -> CheckoutPage : Nhap thong tin va bam "Xac nhan dat hang"
CheckoutPage -> CustomerOrderController : POST /api/customer/orders
CustomerOrderController -> OrderService : createOrderSummary(username,request)
OrderService -> UserRepo : findByUsername(username)
loop Moi dong san pham trong gio
  OrderService -> ProductRepo : findById(productId)
  OrderService -> VariantRepo : findByProductIdOrderBySortOrderAscIdAsc()
  OrderService -> OrderService : Kiem tra ton kho + tinh don gia
  OrderService -> ProductRepo : cap nhat stock
  OrderService -> VariantRepo : cap nhat stock bien the
end
opt Co ma khuyen mai
  OrderService -> PromotionService : findValidPromotionOrThrow(code)
  PromotionService -> PromotionRepo : findByCodeIgnoreCase(code)
  PromotionRepo --> PromotionService : Promotion
  PromotionService --> OrderService : Promotion hop le
end
OrderService -> OrderRepo : saveAndFlush(order + orderItems)
OrderService -> OrderStatusHistoryService : saveHistorySafe(PENDING->PENDING)
OrderService -> EmailNotificationService : sendOrderCreated(order)
OrderService --> CustomerOrderController : OrderSummaryResponse
CustomerOrderController --> CheckoutPage : 201 Created + orderId

alt Khach chon ONLINE_GATEWAY
  Customer -> CheckoutPage : Bam nut "Thanh toan online"
  CheckoutPage -> CustomerPaymentController : POST /api/customer/payments/session
  CustomerPaymentController -> PaymentService : createSession(username,orderId,provider,clientIp)
  PaymentService -> OrderRepo : findById/order cua user
  PaymentService -> OrderRepo : save(paymentReference,\npaymentProvider, onlinePaymentStatus=PENDING)
  PaymentService --> CustomerPaymentController : CreatePaymentSessionResponse(checkoutUrl)
  CustomerPaymentController --> CheckoutPage : checkoutUrl
  CheckoutPage -> PaymentGateway : Redirect checkoutUrl
  PaymentGateway -> PaymentService : Callback return/ipn/webhook
  alt Thanh toan thanh cong
    PaymentService -> OrderRepo : update onlinePaymentStatus=PAID,\npaidAt, paymentProvider
    PaymentService -> OrderStatusHistoryService : saveHistorySafe(...)
    PaymentService -> EmailNotificationService : sendOrderPaymentResult(PAID)
  else Thanh toan that bai/het han
    PaymentService -> OrderRepo : update onlinePaymentStatus=FAILED\nhoac cancel order neu qua han
    PaymentService -> OrderStatusHistoryService : saveHistorySafe(...)
    PaymentService -> EmailNotificationService : sendOrderPaymentResult(FAILED)
  end
  PaymentService --> CheckoutPage : Redirect /payments/result
else Khach chon COD
  CheckoutPage --> Customer : Dat hang thanh cong,\ncho xac nhan don hang
end

alt Thieu thong tin / gio rong / het ton kho /\npromo khong hop le
  OrderService --> CustomerOrderController : IllegalArgumentException
  CustomerOrderController --> CheckoutPage : 400 + thong bao loi
  CheckoutPage --> Customer : Hien thi loi
else Loi CSDL
  OrderRepo --> OrderService : DataAccessException
  CustomerOrderController --> CheckoutPage : 500 Loi he thong
  CheckoutPage --> Customer : Hien thi Loi he thong
end
@enduml

@startuml UC09_sequence
title UC09 - Quan ly thong tin ca nhan
actor "Khach hang" as Customer
boundary "ProfilePage" as ProfilePage
control "CustomerProfileController" as ProfileController
control "ProfileService" as ProfileService
control "PasswordEncoder" as PasswordEncoder
database "UserRepository / users" as UserRepo

Customer -> ProfilePage : Mo trang Tai khoan
ProfilePage -> ProfileController : GET /api/customer/profile
ProfileController -> ProfileService : getProfile(username)
ProfileService -> UserRepo : findByUsername(username)
UserRepo --> ProfileService : User
ProfileService --> ProfileController : ProfileResponse
ProfileController --> ProfilePage : Hien thi thong tin hien tai

Customer -> ProfilePage : Sua fullName/email/phone/address
Customer -> ProfilePage : (Tuy chon) nhap currentPassword + newPassword
Customer -> ProfilePage : Bam nut Luu thay doi
ProfilePage -> ProfileController : PUT /api/customer/profile
ProfileController -> ProfileService : updateProfile(username,request)
ProfileService -> UserRepo : findByUsername(username)
opt Doi mat khau
  ProfileService -> PasswordEncoder : matches(currentPassword, oldHash)
  ProfileService -> PasswordEncoder : encode(newPassword)
end
ProfileService -> UserRepo : save(User)
ProfileService --> ProfileController : ProfileResponse moi
ProfileController --> ProfilePage : 200 + thong bao cap nhat thanh cong

alt Email trung / currentPassword sai / du lieu khong hop le
  ProfileService --> ProfileController : IllegalArgumentException
  ProfileController --> ProfilePage : 400 + thong bao loi
  ProfilePage --> Customer : Hien thi loi
else Loi CSDL
  UserRepo --> ProfileService : DataAccessException
  ProfileController --> ProfilePage : 500 Loi he thong
  ProfilePage --> Customer : Hien thi Loi he thong
